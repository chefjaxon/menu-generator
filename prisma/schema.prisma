generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id               String   @id
  name             String
  description      String?
  instructions     String?
  cuisineType      String   @map("cuisine_type")
  itemType         String   @map("item_type") @default("meal")
  servingSize      Int      @map("serving_size") @default(1)
  recipeKeeperUrl  String?  @map("recipe_keeper_url")
  createdAt        DateTime @map("created_at") @default(now())
  updatedAt        DateTime @map("updated_at") @updatedAt

  ingredients   RecipeIngredient[]
  proteinSwaps  RecipeProteinSwap[]
  tags          RecipeTag[]
  menuItems     MenuItem[]

  @@map("recipes")
}

model RecipeTag {
  id       String @id
  recipeId String @map("recipe_id")
  tag      String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tag])
  @@map("recipe_tags")
}

model RecipeIngredient {
  id        String  @id
  recipeId  String  @map("recipe_id")
  name      String
  quantity  String?
  unit      String?
  role      String  @default("core")
  sortOrder Int     @map("sort_order") @default(0)

  recipe Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  swaps  IngredientSwap[]

  @@map("recipe_ingredients")
}

model IngredientSwap {
  id                   String  @id
  recipeIngredientId   String  @map("recipe_ingredient_id")
  substituteIngredient String  @map("substitute_ingredient")
  substituteQty        String? @map("substitute_qty")
  substituteUnit       String? @map("substitute_unit")
  restriction          String
  priority             Int     @default(0)

  ingredient RecipeIngredient @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  @@map("ingredient_swaps")
}

model RecipeProteinSwap {
  id       String @id
  recipeId String @map("recipe_id")
  protein  String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, protein])
  @@map("recipe_protein_swaps")
}

model Client {
  id              String   @id
  name            String
  itemsPerMenu    Int      @map("items_per_menu") @default(5)
  notes           String?
  chefNotes       String?  @map("chef_notes")
  servingsPerDish Int      @map("servings_per_dish") @default(4)
  dishCount       Int      @map("dish_count") @default(3)
  createdAt       DateTime @map("created_at") @default(now())
  updatedAt       DateTime @map("updated_at") @updatedAt

  proteins           ClientProtein[]
  restrictions       ClientRestriction[]
  cuisinePreferences ClientCuisinePreference[]
  menuComposition    ClientMenuComposition[]
  menus              Menu[]
  account            ClientAccount?
  schedules          ChefSchedule[]

  @@map("clients")
}

model ClientProtein {
  id       String @id
  clientId String @map("client_id")
  protein  String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, protein])
  @@map("client_proteins")
}

model ClientRestriction {
  id          String @id
  clientId    String @map("client_id")
  restriction String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, restriction])
  @@map("client_restrictions")
}

model ClientCuisinePreference {
  id          String @id
  clientId    String @map("client_id")
  cuisineType String @map("cuisine_type")
  weight      Int    @default(3)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, cuisineType])
  @@map("client_cuisine_preferences")
}

model ClientMenuComposition {
  id       String @id
  clientId String @map("client_id")
  category String
  count    Int    @default(0)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, category])
  @@map("client_menu_composition")
}

model Menu {
  id               String    @id
  clientId         String    @map("client_id")
  createdAt        DateTime  @map("created_at") @default(now())
  finalized        Boolean   @default(false)
  weekLabel        String?   @map("week_label")
  groceryGenerated Boolean   @default(false) @map("grocery_generated")
  publishedAt      DateTime? @map("published_at")
  clientToken      String?   @unique @map("client_token")
  pantryToken      String?   @unique @map("pantry_token")
  pantrySubmitted  Boolean   @default(false) @map("pantry_submitted")
  groceryApproved  Boolean   @default(false) @map("grocery_approved")

  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items           MenuItem[]
  groceryItems    GroceryItem[]
  chefAssignments ChefAssignment[]
  scheduleEntry   ChefSchedule?

  @@map("menus")
}

model MenuItem {
  id              String  @id
  menuId          String  @map("menu_id")
  recipeId        String  @map("recipe_id")
  selectedProtein String? @map("selected_protein")
  sortOrder       Int     @map("sort_order") @default(0)
  clientSelected  Boolean @default(false) @map("client_selected")
  omitNotes       String? @map("omit_notes")
  clientNote      String? @map("client_note")

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("menu_items")
}

model Chef {
  id           String   @id
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  sessions    ChefSession[]
  assignments ChefAssignment[]
  schedules   ChefSchedule[]

  @@map("chefs")
}

model ChefSession {
  id        String   @id
  chefId    String   @map("chef_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@map("chef_sessions")
}

model ChefAssignment {
  id     String @id
  chefId String @map("chef_id")
  menuId String @map("menu_id")

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([chefId, menuId])
  @@map("chef_assignments")
}

model User {
  id           String   @id
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @map("created_at") @default(now())

  sessions Session[]

  @@map("users")
}

model ClientAccount {
  id           String   @id
  clientId     String   @unique @map("client_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions ClientSession[]

  @@map("client_accounts")
}

model ClientSession {
  id              String   @id
  clientAccountId String   @map("client_account_id")
  token           String   @unique
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  account ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@map("client_sessions")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @map("created_at") @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Protein {
  id        String @id
  name      String @unique
  sortOrder Int    @map("sort_order") @default(0)

  @@map("proteins")
}

model GroceryItem {
  id           String   @id
  menuId       String   @map("menu_id")
  name         String
  quantity     String?
  unit         String?
  checked      Boolean  @default(false)
  source       String   @default("recipe")
  recipeItemId String?  @map("recipe_item_id")
  notes        String?
  clientNote   String?  @map("client_note")
  sortOrder    Int      @map("sort_order") @default(0)
  category     String   @default("other")
  createdAt    DateTime @map("created_at") @default(now())

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("grocery_items")
}

model ChefSchedule {
  id            String   @id @default(cuid())
  chefId        String   @map("chef_id")
  clientId      String   @map("client_id")
  scheduledDate DateTime @map("scheduled_date")
  scheduledTime String   @map("scheduled_time")
  notes         String?
  recurrenceId  String?  @map("recurrence_id")
  menuId        String?  @unique @map("menu_id")
  createdAt     DateTime @default(now()) @map("created_at")

  chef   Chef   @relation(fields: [chefId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  menu   Menu?  @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@map("chef_schedules")
}
